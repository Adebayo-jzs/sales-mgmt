// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id        String     @id @default(cuid())
  name      String
  category  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  saleItems SaleItem[]
}

model Sale {
  id          String     @id @default(cuid())
  totalAmount  Decimal    @db.Decimal(12, 2)
  totalProfit  Decimal    @db.Decimal(12, 2)
  customerName String?
  createdAt    DateTime   @default(now())
  items        SaleItem[]
}

model SaleItem {
  id           String   @id @default(cuid())
  saleId       String
  productId    String
  quantity     Int
  costPrice    Decimal  @db.Decimal(12, 2)
  sellingPrice Decimal  @db.Decimal(12, 2)
  profit       Decimal  @db.Decimal(12, 2)
  sale         Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id])
}

model BusinessStats {
  id               String   @id @default(cuid())
  initialCapital   Decimal  @db.Decimal(12, 2)
  totalSalesProfit Decimal  @db.Decimal(12, 2) @default(0)
  totalNetProfit   Decimal  @db.Decimal(12, 2) @default(0)
  totalExpenditure Decimal  @db.Decimal(12, 2) @default(0)
  presentValue     Decimal  @db.Decimal(12, 2)
  updatedAt        DateTime @updatedAt
}

model Expenditure {
  id          String   @id @default(cuid())
  amount      Decimal  @db.Decimal(12, 2)
  description String
  createdAt   DateTime @default(now())
}
